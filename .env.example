SECRET_KEY=django-insecure-dev-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3

# OIDC (Sovereign Auth)
OIDC_RP_CLIENT_ID=hiver-client
OIDC_RP_CLIENT_SECRET=
OIDC_OP_AUTHORIZATION_ENDPOINT=https://iyou.me/openid/authorize/
OIDC_OP_TOKEN_ENDPOINT=http://127.0.0.1:8000/openid/token/
OIDC_OP_USER_ENDPOINT=http://127.0.0.1:8000/openid/userinfo/
OIDC_OP_JWKS_ENDPOINT=http://127.0.0.1:8000/openid/jwks/
OIDC_RP_CALLBACK_URL=http://127.0.0.1:8003/oidc/callback/
OIDC_VERIFY_SSL=False

# Session / CSRF isolation
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# CORS / CSRF origins
CORS_ALLOWED_ORIGINS=https://hive.iyou.me,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://hive.iyou.me,http://127.0.0.1:8000

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Vector index
LANCE_DB_PATH=media

# AI providers
MISTRAL_API_KEY=
GEMINI_API_KEY=
LLM_BACKEND=mock
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=llama2
GEMINI_MODEL=gemini-2.5-flash

# Mesh service URLs
POLY_URL=https://poly.iyou.me
SOCIALFEED_URL=https://wun.iyou.me
VAULT_URL=ws://127.0.0.1:9001

# DID
RUST_DID_LIB_PATH=

# Email (optional — for transactional notifications)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=password
